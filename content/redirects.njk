---
pagination:
    data: redirects
    size: 1
    alias: redirect
permalink: "{{ redirect.from }}"
eleventyExcludeFromCollections: true
redirects:
    - from: /guidance/aifriendly/
      to: /guidance/botfriendly/
    - from: /guidance/seo/
      to: /guidance/botfriendly/
    - from: /guidance/content/
      to: /guidance/usability/
    - from: /aifriendly/
      to: /botfriendly/
    - from: /seo/
      to: /botfriendly/
    - from: /content/
      to: /usability/
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="refresh" content="0; url={{ redirect.to }}">
    <link rel="canonical" href="{{ redirect.to }}">
    <title>Redirecting&hellip;</title>
</head>
<body>
    <p>This page has moved. <a href="{{ redirect.to }}">Click here</a> if you are not redirected.</p>
</body>
</html>
